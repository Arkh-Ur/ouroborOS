#!/usr/bin/env bash
# ouroborOS-installer — launcher script for the ouroborOS Python installer
#
# This script is placed in /usr/local/bin on the live ISO. It validates
# the environment and then launches the Python installer module.
#
set -euo pipefail

INSTALLER_DIR="/usr/lib/ouroborOS/installer"
LOG_FILE="/tmp/ouroborOS-install.log"
MIN_PYTHON="3.11"

log_info()  { printf '\033[0;34m[ouroborOS]\033[0m %s\n' "$*"; }
log_error() { printf '\033[0;31m[ouroborOS]\033[0m %s\n' "$*" >&2; }

# Check root
if [[ $EUID -ne 0 ]]; then
    log_error "The installer must be run as root."
    log_error "Use: sudo ouroborOS-installer"
    exit 1
fi

# Check Python version
if ! command -v python3 &>/dev/null; then
    log_error "python3 not found. Is the live environment correctly built?"
    exit 1
fi

py_version=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
if ! python3 -c "import sys; sys.exit(0 if sys.version_info >= (3, 11) else 1)"; then
    log_error "Python ${MIN_PYTHON}+ required, found ${py_version}."
    exit 1
fi

# Check installer module is available
if [[ ! -d "$INSTALLER_DIR" ]]; then
    log_error "Installer not found at ${INSTALLER_DIR}."
    log_error "The live ISO may be corrupted."
    exit 1
fi

log_info "Starting ouroborOS installer (log: ${LOG_FILE})"
log_info "Python: ${py_version}"

# Add installer to PYTHONPATH and launch
export PYTHONPATH="${INSTALLER_DIR}:${PYTHONPATH:-}"

exec python3 -m installer.main "$@"
