#!/usr/bin/env bash
# our-pac — the ONLY safe way to install/upgrade packages on ouroborOS.
#
# Full Phase 4 flow on an installed immutable system:
#   1. Verify ≥ 2 GB free on Btrfs pool (abort if insufficient)
#   2. Create timestamped snapshot + metadata JSON (pre-upgrade baseline)
#   3. Unlock @ via subvolid=5 mount (avoids circular deadlock)
#   4. Remount / read-write
#   5. Run pacman with all arguments forwarded
#   6. Lock @ (Btrfs ro=true) and remount /  ro
#   7. [if sbctl active] sbctl sign-all (post-upgrade EFI re-signing)
#   8. Sync systemd-boot entries for all snapshots
#   9. Write JSON upgrade log to /var/log/our-pac/
#  10. Auto-prune snapshots if count > 10
#
# Why NOT exec pacman:
#   Pacman hooks run alphabetically. Hooks from gtk4, dconf, glib write to
#   /usr/share/* AFTER zzz-post-upgrade. Using exec would hand control to
#   pacman permanently, preventing steps 6-10 from running.
#
# On the live ISO:
#   Simply forwards to pacman (root already writable, no snapshots needed).
set -euo pipefail

readonly PROGRAM_NAME="our-pac"
readonly SNAPSHOT_LIB="/usr/local/lib/ouroboros/snapshot.sh"
readonly LOG_DIR="/var/log/our-pac"
readonly MIN_FREE_GB=2

_msg()  { echo "[${PROGRAM_NAME}] $*"; }
_warn() { echo "[${PROGRAM_NAME}] WARNING: $*" >&2; }
_err()  { echo "[${PROGRAM_NAME}] ERROR: $*" >&2; }

if [[ $EUID -ne 0 ]]; then
    exec sudo "/usr/local/bin/${PROGRAM_NAME}" "$@"
fi

# ── Helpers ───────────────────────────────────────────────────────────────────

is_immutable_root() {
    btrfs property get / ro 2>/dev/null | grep -q 'ro=true'
}

# Unlock root via top-level Btrfs mount (avoids circular deadlock).
# btrfs property set / ro false fails when VFS mount is ro — kernel blocks
# metadata writes when superblock is mounted ro. Mounting subvolid=5 to a
# temp dir provides a separate rw mount point for the property change.
unlock_root() {
    local root_dev tmp
    root_dev=$(findmnt -n -o SOURCE / | sed 's/\[.*//')
    tmp=$(mktemp -d)

    if ! mount -t btrfs -o subvolid=5 "$root_dev" "$tmp" 2>/dev/null; then
        rmdir "$tmp"
        _err "Could not mount Btrfs top-level from ${root_dev}"
        exit 1
    fi

    if ! btrfs property set "${tmp}/@" ro false 2>/dev/null; then
        umount "$tmp"; rmdir "$tmp"
        _err "Could not clear Btrfs ro property on @"
        exit 1
    fi

    umount "$tmp"; rmdir "$tmp"
    mount -o remount,rw /
    _msg "Root unlocked (Btrfs ro=false) and remounted read-write"
}

# Lock root after pacman + all its hooks have finished.
lock_root() {
    local root_dev tmp
    root_dev=$(findmnt -n -o SOURCE / | sed 's/\[.*//')
    tmp=$(mktemp -d)

    if mount -t btrfs -o subvolid=5 "$root_dev" "$tmp" 2>/dev/null; then
        btrfs property set "${tmp}/@" ro true 2>/dev/null && \
            _msg "Root locked (Btrfs ro=true)"
        umount "$tmp"; rmdir "$tmp"
    else
        rmdir "$tmp"
        _msg "Could not mount top-level — root may remain writable"
    fi
    mount -o remount,ro / 2>/dev/null || \
        _msg "Root busy — Btrfs property protects immutability regardless"
}

# Verify sufficient free space on the Btrfs pool (unallocated + free allocated).
check_free_space() {
    local free_gb
    free_gb=$(btrfs filesystem usage -b / 2>/dev/null \
        | awk '/Free \(estimated\)/{gsub(/,/,""); print int($3/1073741824); exit}')

    if [[ -z "$free_gb" ]]; then
        # Fallback: use df
        free_gb=$(df -BG --output=avail / 2>/dev/null | tail -1 | tr -d 'G ')
    fi

    if [[ -n "$free_gb" && "$free_gb" -lt "$MIN_FREE_GB" ]]; then
        _err "Insufficient disk space: ${free_gb} GB free, need at least ${MIN_FREE_GB} GB."
        _err "Run 'our-snapshot prune' to free space, or delete unused snapshots."
        exit 1
    fi

    _msg "Disk space: ${free_gb:-?} GB free (minimum: ${MIN_FREE_GB} GB)"
}

# Write metadata JSON alongside snapshot.
write_snapshot_metadata() {
    local snap_name="$1"
    local snap_dir="/.snapshots/${snap_name}"
    local meta_file="${snap_dir}.json"
    local kernel_ver
    kernel_ver=$(uname -r 2>/dev/null || echo "unknown")
    local pacman_db_hash
    pacman_db_hash=$(sha256sum /var/lib/pacman/local/ALPM_DB_VERSION 2>/dev/null | awk '{print $1}' || echo "")

    cat > "$meta_file" << EOF
{
  "snapshot": "${snap_name}",
  "timestamp": "$(date -Iseconds)",
  "kernel": "${kernel_ver}",
  "pacman_db_hash": "${pacman_db_hash}",
  "operation": "pre-upgrade",
  "program": "${PROGRAM_NAME}"
}
EOF
    chmod 644 "$meta_file"
}

# Append a JSON entry to /var/log/our-pac/YYYY-MM-DD.json
write_upgrade_log() {
    local snap_name="$1"
    local pacman_exit="$2"
    local start_ts="$3"
    local end_ts
    end_ts=$(date -Iseconds)
    local args="${*:4}"

    mkdir -p "$LOG_DIR"
    local log_file
    log_file="${LOG_DIR}/$(date +%Y-%m-%d).json"

    # Append newline-delimited JSON (one object per line)
    cat >> "$log_file" << EOF
{"timestamp":"${end_ts}","start":"${start_ts}","snapshot":"${snap_name}","exit":${pacman_exit},"args":$(printf '%s' "${args}" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read().split()))" 2>/dev/null || echo '"'"${args}"'"')}
EOF
}

# Re-sign EFI binaries if sbctl is installed and Secure Boot keys are enrolled.
sign_after_upgrade() {
    command -v sbctl &>/dev/null || return 0
    sbctl status 2>/dev/null | grep -q "Installed.*true\|Keys.*installed" || return 0

    _msg "Secure Boot: re-signing EFI binaries with sbctl..."
    sbctl sign-all 2>/dev/null || \
        _warn "sbctl sign-all encountered errors. Run: sudo ouroboros-secureboot sign-all"
}

# Sync systemd-boot entries for all snapshots (no-op if our-snapshot missing)
sync_boot_entries() {
    local snap_tool="/usr/local/bin/our-snapshot"
    [[ -x "$snap_tool" ]] || return 0
    _msg "Syncing systemd-boot entries for snapshots..."
    "$snap_tool" sync-boot-entries 2>/dev/null || \
        _warn "Boot entry sync failed. Run: sudo our-snapshot sync-boot-entries"
}

# Prune snapshots if count > 10 (safety cap regardless of age policy)
auto_prune_if_needed() {
    local snap_tool="/usr/local/bin/our-snapshot"
    [[ -x "$snap_tool" ]] || return 0

    local count
    count=$(find "/.snapshots" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)
    if [[ "$count" -gt 10 ]]; then
        _msg "Snapshot count (${count}) exceeds 10 — auto-pruning..."
        "$snap_tool" prune --keep 5 --days 30 2>/dev/null || \
            _warn "Auto-prune failed. Run: sudo our-snapshot prune"
    fi
}

# Update user_packages list in /etc/ouroboros/system.yaml.
# Called after explicit -S (install) or -R/-Rs (remove) operations.
# Skipped for upgrades (-Syu/-Su) — those don't add new user packages.
update_system_yaml_packages() {
    local operation="$1"   # "add" or "remove"
    shift
    local pkgs=("$@")
    local yaml_file="/etc/ouroboros/system.yaml"

    [[ -f "$yaml_file" ]] || return 0
    [[ ${#pkgs[@]} -eq 0 ]] && return 0
    command -v python3 >/dev/null 2>&1 || return 0

    python3 - "$yaml_file" "$operation" "${pkgs[@]}" << 'PYEOF'
import sys, yaml, os

yaml_path = sys.argv[1]
operation = sys.argv[2]
pkgs = sys.argv[3:]

try:
    with open(yaml_path, encoding="utf-8") as f:
        data = yaml.safe_load(f)
except Exception:
    sys.exit(0)

user_pkgs = data.get("user_packages", [])
if not isinstance(user_pkgs, list):
    user_pkgs = []

if operation == "add":
    for p in pkgs:
        if p not in user_pkgs:
            user_pkgs.append(p)
elif operation == "remove":
    user_pkgs = [p for p in user_pkgs if p not in pkgs]

data["user_packages"] = sorted(user_pkgs)

tmp = yaml_path + ".tmp"
with open(tmp, "w", encoding="utf-8") as f:
    yaml.dump(data, f, default_flow_style=False, allow_unicode=True, sort_keys=False)
os.replace(tmp, yaml_path)
PYEOF
}

# Determine if args represent an explicit install or remove (not upgrade)
_pac_operation() {
    local args=("$@")
    local flags=""
    for a in "${args[@]}"; do
        [[ "$a" == -* ]] && flags+="${a#-}"
    done
    # -Syu / -Su → upgrade only (no user_packages change)
    if [[ "$flags" == *u* && "$flags" == *S* ]]; then
        echo "upgrade"
    elif [[ "$flags" == *S* ]]; then
        echo "install"
    elif [[ "$flags" == *R* ]]; then
        echo "remove"
    else
        echo "other"
    fi
}

# Extract non-flag arguments (package names)
_pac_pkg_names() {
    local pkgs=()
    for a in "$@"; do
        [[ "$a" == -* ]] || pkgs+=("$a")
    done
    printf '%s\n' "${pkgs[@]}"
}

# ── Main flow ─────────────────────────────────────────────────────────────────

if is_immutable_root; then
    _msg "Preparing package operation on immutable root..."
    start_ts=$(date -Iseconds)

    # 1. Space check
    check_free_space

    # 2. Snapshot + metadata
    snap_name=""
    if [[ -r "$SNAPSHOT_LIB" ]]; then
        # shellcheck source=/dev/null
        source "$SNAPSHOT_LIB"

        snap_name=$(date +%Y-%m-%dT%H%M%S)
        _msg "Creating pre-upgrade snapshot: ${snap_name}"
        create_snapshot "/" "/.snapshots/${snap_name}" --readonly 2>/dev/null || \
            _warn "Snapshot creation failed — continuing without snapshot"

        if [[ -d "/.snapshots/${snap_name}" ]]; then
            write_snapshot_metadata "$snap_name"
            generate_snapshot_boot_entry "$snap_name" "/boot" "quiet ro" 2>/dev/null || true
        fi
    else
        _warn "Snapshot library not found at ${SNAPSHOT_LIB} — skipping snapshot"
    fi

    # 3-4. Unlock and remount rw
    unlock_root

    # Guarantee root is re-locked on ANY exit path (success, error, SIGINT, SIGTERM).
    # Without this, `set -e` aborts mid-flow if pacman returns non-zero (e.g. user
    # cancels with "n") and root stays writable until next reboot.
    # _pac_cleanup_done=1 is set after the explicit lock+sync below so the trap
    # skips the redundant second call on the success path.
    _pac_cleanup_done=0
    trap '
        if [[ "$_pac_cleanup_done" -eq 0 ]]; then
            lock_root 2>/dev/null || true
            sync_boot_entries 2>/dev/null || true
        fi
    ' EXIT

    # 5. Stale lock check — remove db.lck only if no pacman process is running
    _PACMAN_LOCK="/var/lib/pacman/db.lck"
    if [[ -f "$_PACMAN_LOCK" ]]; then
        if pgrep -x pacman > /dev/null 2>&1; then
            _err "pacman is already running (lock: $_PACMAN_LOCK). Aborting."
            exit 1
        fi
        _warn "Stale pacman lock detected — removing $_PACMAN_LOCK"
        rm -f "$_PACMAN_LOCK"
    fi

    # 6. Run pacman
    _msg "Running: pacman $*"
    pacman_exit=0
    /usr/bin/pacman "$@" || pacman_exit=$?

    # 6b. Update system.yaml user_packages for explicit installs/removes
    if [[ "$pacman_exit" -eq 0 ]]; then
        _pac_op=$(_pac_operation "$@")
        mapfile -t _pac_pkgs < <(_pac_pkg_names "$@")
        if [[ "$_pac_op" == "install" ]]; then
            update_system_yaml_packages "add" "${_pac_pkgs[@]}"
        elif [[ "$_pac_op" == "remove" ]]; then
            update_system_yaml_packages "remove" "${_pac_pkgs[@]}"
        fi
    fi

    # 7. Lock root (trap also runs on exit, but explicit call keeps the order
    #    deterministic for the steps below)
    lock_root

    # 8. sbctl sign-all (if Secure Boot active)
    sign_after_upgrade

    # 9. Sync boot entries — mark cleanup done so the EXIT trap skips the duplicate
    sync_boot_entries
    _pac_cleanup_done=1

    # 9. Write upgrade log
    if [[ -n "$snap_name" ]]; then
        write_upgrade_log "$snap_name" "$pacman_exit" "$start_ts" "$@" 2>/dev/null || true
    fi

    # 10. Auto-prune if snapshot count > 10
    auto_prune_if_needed

    exit "$pacman_exit"
else
    _msg "Running: pacman $* (writable root — live ISO or unlocked)"
    exec /usr/bin/pacman "$@"
fi
