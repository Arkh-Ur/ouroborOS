#!/usr/bin/env bash
# our-bluetooth — interactive Bluetooth manager for ouroborOS (bluetoothctl wrapper)
#
# Wraps bluetoothctl with a friendly CLI. Requires bluez + bluez-utils.
#
# Usage:
#   our-bluetooth list                  # Scan and list nearby devices
#   our-bluetooth pair <MAC>            # Pair with a device (interactive PIN if needed)
#   our-bluetooth connect <MAC>         # Connect to a paired device
#   our-bluetooth disconnect <MAC>      # Disconnect from a device
#   our-bluetooth forget <MAC>          # Remove pairing
#   our-bluetooth status                # Show adapter status and connected devices
#   our-bluetooth on                    # Enable Bluetooth adapter
#   our-bluetooth off                   # Disable Bluetooth adapter (power off)
#   our-bluetooth le status             # Show BLE (Low Energy) adapter capabilities
#   our-bluetooth le experimental on    # Enable BlueZ experimental mode (FIDO2 QR)
#   our-bluetooth le experimental off   # Disable BlueZ experimental mode
#   our-bluetooth le advmon             # Check AdvertisingMonitor API (QR passkeys)
#   our-bluetooth help
#
# FIDO2 / PASSKEYS / QR CODE:
#   For BLE FIDO2 tokens and hybrid QR passkey flow, see: our-fido2 qr-ready
#   BlueZ experimental mode is required for CTAP2 hybrid transport.
#   Enable it with: our-bluetooth le experimental on
#
# Requirements:
#   - bluez and bluez-utils packages installed
#   - bluetooth.service running (systemctl start bluetooth)
#   - libfido2 for FIDO2 key management (our-fido2)
set -euo pipefail

readonly PROGRAM="our-bluetooth"
readonly SCAN_TIMEOUT=10   # seconds to scan before listing

_info()  { printf '\033[0;34m[%s]\033[0m %s\n'  "$PROGRAM" "$*"; }
_ok()    { printf '\033[0;32m[%s]\033[0m %s\n'  "$PROGRAM" "$*"; }
_warn()  { printf '\033[0;33m[%s]\033[0m %s\n'  "$PROGRAM" "$*" >&2; }
_err()   { printf '\033[0;31m[%s]\033[0m %s\n'  "$PROGRAM" "$*" >&2; }
_die()   { _err "$*"; exit 1; }

# ── Helpers ───────────────────────────────────────────────────────────────────

_require_bluetoothctl() {
    command -v bluetoothctl &>/dev/null || \
        _die "bluetoothctl not found. Install: sudo our-pacman -S bluez bluez-utils"
}

_require_bluetooth_service() {
    systemctl is-active --quiet bluetooth.service 2>/dev/null || {
        _warn "bluetooth.service is not running. Starting it now..."
        systemctl start bluetooth.service || \
            _die "Failed to start bluetooth.service. Is bluez installed?"
    }
}

_validate_mac() {
    local mac="$1"
    [[ "$mac" =~ ^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$ ]] || \
        _die "Invalid MAC address: '${mac}'. Expected format: AA:BB:CC:DD:EE:FF"
}

# Run a bluetoothctl command sequence and return output
_btctl() {
    bluetoothctl "$@" 2>/dev/null
}

# Send commands to bluetoothctl via stdin (for interactive sequences)
_btctl_cmd() {
    local timeout_s="${1}"; shift
    printf '%s\n' "$@" | timeout "$timeout_s" bluetoothctl 2>/dev/null || true
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_list() {
    _require_bluetoothctl
    _require_bluetooth_service

    _info "Scanning for ${SCAN_TIMEOUT}s..."
    _btctl_cmd "$(( SCAN_TIMEOUT + 2 ))" \
        "scan on" \
        "$(sleep "${SCAN_TIMEOUT}"; echo "scan off")" \
        "devices" \
        "quit" 2>/dev/null || true

    echo ""
    _info "Known/discovered devices:"
    _btctl devices 2>/dev/null | while IFS= read -r line; do
        local mac name
        mac=$(echo "$line" | awk '{print $2}')
        name=$(echo "$line" | cut -d' ' -f3-)
        # Check if connected
        local connected="  "
        _btctl info "$mac" 2>/dev/null | grep -q "Connected: yes" && connected="✓ "
        echo "  ${connected}${mac}  ${name}"
    done
}

cmd_pair() {
    local mac="${1:?Usage: ${PROGRAM} pair <MAC>}"
    _validate_mac "$mac"
    _require_bluetoothctl
    _require_bluetooth_service

    _info "Scanning briefly to discover '${mac}'..."
    _btctl_cmd 5 "scan on" "quit" 2>/dev/null || true

    _info "Pairing with ${mac}..."
    _info "(If the device requires a PIN, confirm it on both sides)"

    # Use bluetoothctl interactively for pairing (PIN exchange)
    bluetoothctl -- pair "$mac" 2>/dev/null && {
        _ok "Paired with ${mac}."
        _info "Now connect with: ${PROGRAM} connect ${mac}"
    } || {
        _warn "Pairing may have failed. Check if device is in pairing mode."
        _info "Run '${PROGRAM} list' to verify device is visible."
    }
}

cmd_connect() {
    local mac="${1:?Usage: ${PROGRAM} connect <MAC>}"
    _validate_mac "$mac"
    _require_bluetoothctl
    _require_bluetooth_service

    _info "Connecting to ${mac}..."
    if _btctl connect "$mac" 2>/dev/null | grep -q "Connection successful"; then
        _ok "Connected to ${mac}."
    else
        _warn "Connection may have failed. Is the device paired and in range?"
        _info "Pair first with: ${PROGRAM} pair ${mac}"
    fi
}

cmd_disconnect() {
    local mac="${1:?Usage: ${PROGRAM} disconnect <MAC>}"
    _validate_mac "$mac"
    _require_bluetoothctl
    _require_bluetooth_service

    _info "Disconnecting ${mac}..."
    _btctl disconnect "$mac" 2>/dev/null && _ok "Disconnected." || \
        _warn "Device may not have been connected."
}

cmd_forget() {
    local mac="${1:?Usage: ${PROGRAM} forget <MAC>}"
    _validate_mac "$mac"
    _require_bluetoothctl
    _require_bluetooth_service

    _info "Removing pairing with ${mac}..."
    _btctl remove "$mac" 2>/dev/null && _ok "Pairing removed for ${mac}." || \
        _warn "Could not remove pairing. Was it paired?"
}

cmd_status() {
    _require_bluetoothctl

    _info "Adapter status:"
    _btctl show 2>/dev/null | grep -E "Name:|Powered:|Discoverable:|Pairable:|Address:" | \
        sed 's/^/  /' || _warn "Could not get adapter info."

    echo ""
    _info "Connected devices:"
    local found=false
    _btctl devices Connected 2>/dev/null | while IFS= read -r line; do
        echo "  ${line}"
        found=true
    done
    $found || echo "  (none)"
}

cmd_on() {
    _require_bluetoothctl
    _require_bluetooth_service

    _info "Powering on Bluetooth adapter..."
    _btctl power on 2>/dev/null && _ok "Bluetooth adapter powered on." || \
        _die "Failed to power on Bluetooth adapter."
}

cmd_off() {
    _require_bluetoothctl
    _require_bluetooth_service

    _info "Powering off Bluetooth adapter..."
    _btctl power off 2>/dev/null && _ok "Bluetooth adapter powered off." || \
        _warn "Could not power off adapter."
}

cmd_le() {
    local subcommand="${1:-status}"; shift || true

    case "$subcommand" in
        status)
            _info "Bluetooth LE (Low Energy) adapter status:"
            echo ""

            if ! command -v bluetoothctl &>/dev/null; then
                _die "bluetoothctl not found. Install: sudo our-pacman -S bluez-utils"
            fi

            # Adapter info
            local adapter_info
            adapter_info=$(bluetoothctl show 2>/dev/null || true)

            if [[ -z "$adapter_info" ]]; then
                _warn "No Bluetooth adapter found."
                return 1
            fi

            echo "$adapter_info" | grep -E "Address:|Name:|Powered:|Discovering:|Pairable:" | \
                sed 's/^/  /' || true
            echo ""

            # Check experimental mode
            local exp_mode="disabled"
            if systemctl cat bluetooth.service 2>/dev/null | grep -q -- "--experimental"; then
                exp_mode="enabled (via service drop-in)"
            elif [[ -f /etc/bluetooth/main.conf ]] && \
                 grep -qi "^Experimental\s*=\s*true" /etc/bluetooth/main.conf 2>/dev/null; then
                exp_mode="enabled (via main.conf)"
            fi
            printf '  %-30s %s\n' "Experimental mode:" "$exp_mode"

            # Check AdvertisingMonitor (key for FIDO2 QR/hybrid)
            local advmon="unavailable"
            if command -v busctl &>/dev/null; then
                if busctl introspect org.bluez /org/bluez 2>/dev/null | \
                    grep -q "AdvertisementMonitorManager"; then
                    advmon="available (QR passkey ready)"
                fi
            fi
            printf '  %-30s %s\n' "AdvertisingMonitor API:" "$advmon"

            echo ""
            _dim "  For full FIDO2/QR readiness check: our-fido2 qr-ready"
            ;;

        experimental)
            local action="${1:-}"; shift || true

            case "$action" in
                on)
                    local drop_in_dir="/etc/systemd/system/bluetooth.service.d"
                    local drop_in="${drop_in_dir}/experimental.conf"

                    if [[ -f "$drop_in" ]]; then
                        _ok "Experimental mode already configured at ${drop_in}"
                    else
                        _info "Creating experimental mode drop-in..."
                        mkdir -p "$drop_in_dir"
                        cat > "$drop_in" << 'DROPIN'
# Generated by our-bluetooth le experimental on
[Service]
ExecStart=
ExecStart=/usr/lib/bluetooth/bluetoothd --experimental
DROPIN
                        _ok "Drop-in written: ${drop_in}"
                    fi

                    _info "Also enabling Experimental = true in /etc/bluetooth/main.conf..."
                    if [[ -f /etc/bluetooth/main.conf ]]; then
                        if ! grep -qi "^Experimental" /etc/bluetooth/main.conf; then
                            sed -i '/^\[General\]/a Experimental = true' \
                                /etc/bluetooth/main.conf 2>/dev/null || \
                                _warn "Could not update main.conf — edit manually."
                        fi
                    else
                        mkdir -p /etc/bluetooth
                        printf '[General]\nExperimental = true\n' > /etc/bluetooth/main.conf
                    fi

                    systemctl daemon-reload 2>/dev/null || true
                    _ok "Experimental mode enabled."
                    _info "Restart bluetooth.service to apply:"
                    echo "  systemctl restart bluetooth.service"
                    ;;

                off)
                    local drop_in="/etc/systemd/system/bluetooth.service.d/experimental.conf"
                    if [[ -f "$drop_in" ]]; then
                        rm -f "$drop_in"
                        _ok "Experimental drop-in removed."
                    else
                        _info "No experimental drop-in found."
                    fi

                    if [[ -f /etc/bluetooth/main.conf ]]; then
                        sed -i '/^Experimental\s*=/d; /^KernelExperimental\s*=/d' \
                            /etc/bluetooth/main.conf 2>/dev/null || true
                        _ok "Experimental flags removed from main.conf."
                    fi

                    systemctl daemon-reload 2>/dev/null || true
                    _ok "Experimental mode disabled."
                    _info "Restart bluetooth.service to apply:"
                    echo "  systemctl restart bluetooth.service"
                    ;;

                *)
                    _err "Usage: ${PROGRAM} le experimental on|off"
                    exit 1
                    ;;
            esac
            ;;

        advmon)
            _info "Checking AdvertisingMonitor API (required for CTAP2 QR passkey)..."
            echo ""

            if ! command -v busctl &>/dev/null; then
                _warn "busctl not found. Cannot query D-Bus."
                _dim "  Install: systemd (should already be present)"
                return 1
            fi

            if ! systemctl is-active --quiet bluetooth.service 2>/dev/null; then
                _err "bluetooth.service is not running."
                return 1
            fi

            if busctl introspect org.bluez /org/bluez 2>/dev/null | \
                grep -q "AdvertisementMonitorManager"; then
                _ok "AdvertisingMonitor API is available."
                echo ""
                echo "  Chrome/Firefox can detect phone authenticators for QR passkey flow."

                # Show supported monitor types if possible
                local types
                types=$(busctl call org.bluez /org/bluez \
                    org.bluez.AdvertisementMonitorManager1 \
                    GetSupportedMonitorTypes 2>/dev/null || true)
                [[ -n "$types" ]] && echo "  Supported monitor types: ${types}"
            else
                _err "AdvertisingMonitor API is NOT available."
                echo ""
                _dim "  This is the BlueZ experimental API used by Chrome/Firefox for"
                _dim "  the CTAP2 hybrid transport (QR code passkey) flow."
                echo ""
                _info "  To enable:"
                echo "    ${PROGRAM} le experimental on"
                echo "    systemctl restart bluetooth.service"
                return 1
            fi
            ;;

        *)
            _err "Unknown le subcommand: '${subcommand}'"
            echo "  Usage: ${PROGRAM} le status|experimental on|off|advmon"
            exit 1
            ;;
    esac
}

cmd_help() {
    cat << EOF
${PROGRAM} — Bluetooth manager for ouroborOS (bluetoothctl wrapper)

USAGE
  ${PROGRAM} <command> [options]

COMMANDS
  list                        Scan and list nearby + paired devices (✓ = connected)
  pair <MAC>                  Pair with a device (interactive PIN if needed)
  connect <MAC>               Connect to a paired device
  disconnect <MAC>            Disconnect from a device
  forget <MAC>                Remove device pairing
  status                      Show adapter status and connected devices
  on                          Power on the Bluetooth adapter
  off                         Power off the Bluetooth adapter
  help                        Show this help

  le status                   Show BLE (Low Energy) adapter capabilities
  le experimental on          Enable BlueZ experimental mode (required for QR passkeys)
  le experimental off         Disable BlueZ experimental mode
  le advmon                   Check AdvertisingMonitor API readiness

FIDO2 / PASSKEYS / QR CODE
  For FIDO2 management and hybrid QR passkey flow, use our-fido2:
    our-fido2 qr-ready          Full readiness check for QR/passkey
    our-fido2 ble scan          Scan for BLE FIDO2 authenticators
    our-fido2 ble pair <MAC>    Pair a BLE FIDO2 token
    our-fido2 list              List all connected FIDO2 authenticators
    our-fido2 info <device>     Show authenticator capabilities

EXAMPLES
  ${PROGRAM} list
  ${PROGRAM} pair AA:BB:CC:DD:EE:FF
  ${PROGRAM} connect AA:BB:CC:DD:EE:FF
  ${PROGRAM} disconnect AA:BB:CC:DD:EE:FF
  ${PROGRAM} forget AA:BB:CC:DD:EE:FF
  ${PROGRAM} status
  ${PROGRAM} le status
  ${PROGRAM} le experimental on

REQUIREMENTS
  - bluez and bluez-utils installed
  - bluetooth.service running (auto-started by this tool if needed)
  - libfido2 for FIDO2/passkey management (our-fido2)
  - Install: sudo our-pacman -S bluez bluez-utils libfido2

NOTES
  - MAC address format: AA:BB:CC:DD:EE:FF
  - 'pair' may prompt for PIN confirmation on both the device and terminal
  - Use 'on'/'off' to control the adapter power state
  - BlueZ experimental mode is required for CTAP2 QR hybrid transport
    (the "scan QR code with phone" passkey flow in Chrome/Firefox)
EOF
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

command="${1:-help}"
shift || true

case "$command" in
    list)           cmd_list ;;
    pair)           cmd_pair "${1:-}" ;;
    connect)        cmd_connect "${1:-}" ;;
    disconnect)     cmd_disconnect "${1:-}" ;;
    forget)         cmd_forget "${1:-}" ;;
    status)         cmd_status ;;
    on)             cmd_on ;;
    off)            cmd_off ;;
    le)             cmd_le "${1:-status}" "${2:-}" "${3:-}" ;;
    help|--help|-h) cmd_help ;;
    *)
        _err "Unknown command: ${command}"
        echo ""
        cmd_help
        exit 1
        ;;
esac
