# ouroborOS — sshd config for live ISO (debug/testing only)
# WARNING: This is intentionally permissive for debugging. Do NOT use in production.

Port 22
ListenAddress 0.0.0.0

# Auth
PermitRootLogin yes
PasswordAuthentication yes
ChallengeResponseAuthentication no
UsePAM yes

# Disable strict modes for live env (permissions may be relaxed)
StrictModes no

# Logging
SyslogFacility AUTH
LogLevel INFO

# Allow agent forwarding for convenience
AllowAgentForwarding yes
AllowTcpForwarding yes

# Subsystem
Subsystem sftp /usr/lib/ssh/sftp-server
