# ouroborOS Installer — Deutsch (Deutschland)
msgid ""
msgstr ""
"Project-Id-Version: ouroborOS installer\n"
"Report-Msgid-Bugs-To: https://github.com/Arkh-Ur/ouroborOS/issues\n"
"Language: de_DE\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "Welcome to the ouroborOS installer."
msgstr "Willkommen beim ouroborOS-Installer."

msgid "ouroborOS is an ArchLinux-based distribution with an immutable\nBtrfs root filesystem and a fully systemd-native stack."
msgstr "ouroborOS ist eine auf ArchLinux basierende Distribution mit einem\nunveränderlichen Btrfs-Root-Dateisystem und einem vollständig systemd-nativen Stack."

msgid "This installer will guide you through the installation process."
msgstr "Dieser Installer führt Sie durch den Installationsprozess."

msgid "WARNING: This will ERASE the target disk completely."
msgstr "WARNUNG: Dies wird den Zieldatenträger vollständig LÖSCHEN."

msgid "Select system locale:"
msgstr "Systemsprache auswählen:"

msgid "Select keyboard layout:"
msgstr "Tastaturbelegung auswählen:"

msgid "Enter timezone (e.g. America/New_York, Europe/Madrid, UTC)"
msgstr "Zeitzone eingeben (z.B. Europe/Berlin, UTC)"

msgid "Select a desktop profile for the installed system:"
msgstr "Desktop-Profil für das installierte System auswählen:"

msgid "Select a display manager:"
msgstr "Anzeigemanager auswählen:"

msgid "Select the target disk for installation.\nWARNING: All data on the selected disk will be ERASED."
msgstr "Zieldatenträger für die Installation auswählen.\nWARNUNG: Alle Daten auf dem ausgewählten Laufwerk werden GELÖSCHT."

msgid "Enable LUKS2 full-disk encryption?"
msgstr "LUKS2-Vollverschlüsselung aktivieren?"

msgid "Enter username for the primary user"
msgstr "Benutzername für den Hauptbenutzer eingeben"

msgid "Confirm password"
msgstr "Passwort bestätigen"

msgid "Select the login shell for your user account:"
msgstr "Anmelde-Shell für Ihr Benutzerkonto auswählen:"

msgid "Select the GPU driver to install:"
msgstr "GPU-Treiber zum Installieren auswählen:"

msgid "Installation Complete"
msgstr "Installation Abgeschlossen"

msgid "Remove the installation media."
msgstr "Installationsmedium entfernen."
